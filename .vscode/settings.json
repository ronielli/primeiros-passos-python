{
  // Usa o Python do nosso venv (e não o global)
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

  // Configurações específicas para arquivos Python
  "[python]": {
    // Formatar com o Ruff toda vez que salvar
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,

    // Ao salvar, também: organizar imports e aplicar os --fix do lint
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },

  // Corretor ortográfico (cSpell): reconhece inglês E português do Brasil,
  // assim os comentários em pt-BR param de aparecer como "Unknown word".
  "cSpell.language": "en,pt,pt_BR",

  // --- Autocomplete / IntelliSense (Pylance) ---
  // Garante que o Pylance é o "language server" (quem dá o autocomplete).
  "python.languageServer": "Pylance",
  // Análise mais completa: sugere imports automáticos e checagem básica de tipos.
  "python.analysis.autoImportCompletions": true,
  "python.analysis.typeCheckingMode": "basic",
  // Completa parênteses de função automaticamente ao aceitar uma sugestão.
  "python.analysis.completeFunctionParens": true
}
